# MiniMax text generation. Required for live roadbook generation.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_FAST_MODEL=MiniMax-M2.7-highspeed
MINIMAX_QUALITY_MODEL=MiniMax-M3
MINIMAX_THINKING=disabled
MINIMAX_PREVIEW_MAX_COMPLETION_TOKENS=1800
MINIMAX_PREVIEW_TIMEOUT_MS=60000
MINIMAX_MAX_COMPLETION_TOKENS=5000
MINIMAX_TIMEOUT_MS=180000

# MiniMax-M3 scenic photo-to-render design. Optional but recommended for /dream.
MINIMAX_SCENIC_MODEL=MiniMax-M3
MINIMAX_SCENIC_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_SCENIC_PATH=text/chatcompletion_v2
MINIMAX_SCENIC_TIMEOUT_MS=120000
MINIMAX_SCENIC_MAX_COMPLETION_TOKENS=2200
MINIMAX_SCENIC_MAX_IMAGE_BYTES=6291456

# MiniMax image generation. Optional; falls back to the procedural Three.js scene when absent.
# Uses MINIMAX_API_KEY by default. Set MINIMAX_IMAGE_API_KEY only if the image endpoint uses a separate key.
MINIMAX_IMAGE_API_KEY=
MINIMAX_IMAGE_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_IMAGE_MODEL=image-01
MINIMAX_IMAGE_TIMEOUT_MS=120000
PREVIEW_ASSET_CACHE=on

# Amap Web Service geocoding. Required for live map coordinates.
# Use the Web Service key. Do not paste keys into source files.
AMAP_KEY=

# Optional UI label for the model shown in the app.
NEXT_PUBLIC_AGENT_MODEL_LABEL=MiniMax-M3
